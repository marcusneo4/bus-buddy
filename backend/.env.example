# ============================================================
# Bus Aunty Dashboard - Backend Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Required: LTA DataMall API key
# Obtain from https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
LTA_API_KEY=your_lta_api_key_here

# Server port (default: 3001)
PORT=3001

# LTA API base URL (default: production endpoint)
LTA_BASE_URL=https://datamall2.mytransport.sg/ltaodataservice

# Weather API (Open-Meteo — free, no key needed)
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
SINGAPORE_LAT=1.3521
SINGAPORE_LON=103.8198

# Cache TTL for bus data in milliseconds (default 25s — under 30s refresh cycle)
CACHE_TTL_MS=25000

# Node environment
NODE_ENV=development
